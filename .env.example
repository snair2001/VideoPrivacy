# PrivateStream Arbitrum - Environment Variables
# Copy this file to .env.local and fill in the values

# Pinata IPFS Configuration (required)
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# Arbitrum Sepolia Configuration (required)
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_CONTRACT_ADDRESS=your_deployed_contract_address_here

# Platform Configuration
REVENUE_CAP_USD=20
PLATFORM_FEE_PERCENTAGE=10
ETH_USD_FALLBACK=3000
ALLOW_MOCK_PAYMENT=false

# Optional: Node Environment
NODE_ENV=development

# Note: For FHE, we don't need ENCRYPTION_MASTER_KEY anymore (keys are generated in-memory)
